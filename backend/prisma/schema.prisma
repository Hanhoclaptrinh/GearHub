generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "./ERD.svg"
}

// ====================== USER & PROFILE ======================
model User {
  id        String     @id @default(uuid()) @db.VarChar(36)
  email     String     @unique @db.VarChar(191)
  password  String     @db.VarChar(255)
  role      Role       @default(USER)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  profile      Profile?
  activityLogs ActivityLog[]
  carts        Cart?
  wishlists    Wishlist[]
  orders       Order[]
  chatRooms    ChatRoom[]    @relation("UserChatRooms")
  staffRooms   ChatRoom[]    @relation("StaffChatRooms")
  reviews      Review[]
  sentMessages Message[]     @relation("SenderMessages")

  @@map("users")
}

model Profile {
  id          String  @id @default(uuid()) @db.VarChar(36)
  userId      String  @unique @map("user_id") @db.VarChar(36)
  fullName    String? @map("full_name") @db.VarChar(255)
  phone       String  @unique @db.VarChar(20)
  address     String? @db.Text
  avatarUrl   String? @map("avatar_url") @db.VarChar(255)
  preferences Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ====================== PRODUCT ======================
model Category {
  id          String  @id @default(uuid()) @db.VarChar(36)
  name        String  @db.VarChar(100)
  slug        String  @unique @db.VarChar(100)
  description String? @db.Text
  iconUrl     String? @map("icon_url") @db.VarChar(255)

  parentId String?    @map("parent_id") @db.VarChar(36)
  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: Cascade)
  children Category[] @relation("SubCategories")

  products Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@map("categories")
}

model Brand {
  id       String  @id @default(uuid()) @db.VarChar(36)
  name     String  @db.VarChar(100)
  slug     String  @unique @db.VarChar(100)
  logoUrl  String? @map("logo_url") @db.VarChar(255)
  isActive Boolean @default(true) @map("is_active")

  products Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@map("brands")
}

model Product {
  id           String   @id @default(uuid()) @db.VarChar(36)
  categoryId   String?  @map("category_id") @db.VarChar(36)
  brandId      String?  @map("brand_id") @db.VarChar(36)
  name         String   @db.VarChar(255)
  slug         String   @unique @db.VarChar(255)
  soldCount    Int      @default(0) @map("sold_count")
  viewsCount   Int      @default(0) @map("views_count")
  metadata     Json?
  description  String?  @db.Text
  thumbnailUrl String?  @map("thumbnail_url") @db.VarChar(255)
  tagline      String?  @db.VarChar(150)
  isFeatured   Boolean  @default(false)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  averageRating Float @default(0) @map("average_rating")
  reviewCount   Int   @default(0) @map("review_count")

  category Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand    Brand?           @relation(fields: [brandId], references: [id], onDelete: SetNull)
  variants ProductVariant[]
  assets   ProductAsset[]
  wishlist Wishlist[]
  reviews  Review[]

  @@index([slug])
  @@index([categoryId])
  @@index([brandId])
  @@index([createdAt])
  @@map("products")
}

model ProductVariant {
  id         String  @id @default(uuid()) @db.VarChar(36)
  productId  String  @map("product_id") @db.VarChar(36)
  sku        String  @unique @db.VarChar(100)
  name       String  @db.VarChar(255)
  price      Decimal @db.Decimal(15, 2)
  stock      Int     @default(0)
  attributes Json?
  isActive   Boolean @default(true) @map("is_active")

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([price])
  @@map("product_variants")
}

model ProductAsset {
  id        String    @id @default(uuid()) @db.VarChar(36)
  productId String    @map("product_id") @db.VarChar(36)
  type      AssetType
  url       String    @db.VarChar(255)
  arScale   Float?    @default(1) @map("ar_scale")
  positionX Float?    @default(0) @map("position_x")
  positionY Float?    @default(0) @map("position_y")
  positionZ Float?    @default(0) @map("position_z")
  rotation  Json? // {x: 0, y: 0, z: 0}
  isPrimary Boolean   @default(false) @map("is_primary")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([productId])
  @@map("product_assets")
}

// ====================== CART & WISHLIST ======================
model Cart {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @unique @map("user_id") @db.VarChar(36)
  createdAt DateTime @default(now()) @map("created_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id               String @id @default(uuid()) @db.VarChar(36)
  cartId           String @map("cart_id") @db.VarChar(36)
  productVariantId String @map("product_variant_id") @db.VarChar(36)
  quantity         Int    @default(1)

  cart           Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([cartId, productVariantId])
  @@index([cartId])
  @@index([productVariantId])
  @@map("cart_items")
}

model Wishlist {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @map("user_id") @db.VarChar(36)
  productId String   @map("product_id") @db.VarChar(36)
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlist")
}

// ====================== ORDER ======================
model Order {
  id              String        @id @default(uuid()) @db.VarChar(36)
  userId          String        @map("user_id") @db.VarChar(36)
  totalAmount     Decimal       @map("total_amount") @db.Decimal(15, 2)
  status          OrderStatus   @default(PENDING)
  paymentMethod   PaymentMethod @default(COD) @map("payment_method")
  paymentStatus   PaymentStatus @default(PENDING) @map("payment_status")
  receiverName    String        @map("receiver_name") @db.VarChar(255)
  receiverPhone   String        @map("receiver_phone") @db.VarChar(20)
  shippingAddress String        @map("shipping_address") @db.Text
  note            String?       @db.Text
  createdAt       DateTime      @default(now()) @map("created_at")

  user        User            @relation(fields: [userId], references: [id])
  items       OrderItem[]
  tracking    OrderTracking[]
  transaction Transaction?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id               String @id @default(uuid()) @db.VarChar(36)
  orderId          String @map("order_id") @db.VarChar(36)
  productVariantId String @map("product_variant_id") @db.VarChar(36)

  productName     String  @map("product_name") @db.VarChar(255)
  variantName     String  @map("variant_name") @db.VarChar(255)
  quantity        Int
  priceAtPurchase Decimal @map("price_at_purchase") @db.Decimal(15, 2)

  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])

  @@index([orderId])
  @@index([productVariantId])
  @@map("order_items")
}

model OrderTracking {
  id          String   @id @default(uuid()) @db.VarChar(36)
  orderId     String   @map("order_id") @db.VarChar(36)
  statusLabel String?  @map("status_label") @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_tracking")
}

model Transaction {
  id                    String            @id @default(uuid()) @db.VarChar(36)
  orderId               String            @unique @map("order_id") @db.VarChar(36)
  provider              String?           @db.VarChar(50)
  providerTransactionId String? // ID giao dich tu cong ngan hang
  transactionCode       String?           @map("transaction_code") @db.VarChar(100)
  amount                Decimal           @db.Decimal(15, 2)
  status                TransactionStatus @default(PENDING)
  paymentMethod         PaymentMethod     @map("payment_method")
  paymentDate           DateTime?         @map("payment_date")
  description           String?           @db.VarChar(255)
  rawResponse           String?           @map("raw_response") @db.Text // raw response de tra soat giao dich
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @default(now()) @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

// ====================== CHAT & AI ======================
model ChatRoom {
  id        String     @id @default(uuid()) @db.VarChar(36)
  userId    String     @map("user_id") @db.VarChar(36)
  staffId   String?    @map("staff_id") @db.VarChar(36)
  status    RoomStatus @default(OPEN)
  createdAt DateTime   @default(now()) @map("created_at")

  user      User       @relation("UserChatRooms", fields: [userId], references: [id])
  staff     User?      @relation("StaffChatRooms", fields: [staffId], references: [id])
  messages  Message[]
  aiContext AiContext?

  @@map("chat_rooms")
}

model Message {
  id        String   @id @default(uuid()) @db.VarChar(36)
  roomId    String   @map("room_id") @db.VarChar(36)
  senderId  String?  @map("sender_id") @db.VarChar(36)
  content   String   @db.Text
  isAi      Boolean  @default(false) @map("is_ai")
  createdAt DateTime @default(now()) @map("created_at")

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User?    @relation("SenderMessages", fields: [senderId], references: [id])

  @@index([roomId])
  @@index([createdAt])
  @@map("messages")
}

model AiContext {
  id          String   @id @default(uuid()) @db.VarChar(36)
  roomId      String   @unique @map("room_id") @db.VarChar(36)
  summary     String?  @db.Text
  tokensUsed  Int      @default(0) @map("tokens_used")
  lastUpdated DateTime @default(now()) @updatedAt @map("last_updated")

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("ai_context")
}

// ====================== REVIEW & ACTIVITY ======================
model Review {
  id                 String  @id @default(uuid()) @db.VarChar(36)
  userId             String  @map("user_id") @db.VarChar(36)
  productId          String  @map("product_id") @db.VarChar(36)
  orderId            String? @map("order_id") @db.VarChar(36)
  rating             Int     @default(5)
  comment            String? @db.Text
  reply              String? @db.Text // admin phan hoi
  isVerifiedPurchase Boolean @default(false) @map("is_verified_purchase") // chi cho review khi da mua don hang
  isHidden           Boolean  @default(false) @map("is_hidden")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  assets  ReviewAsset[]

  @@unique([userId, productId]) // moi user chi duoc review 1 san pham 1 lan
  @@map("reviews")
}

model ReviewAsset {
  id       String @id @default(uuid()) @db.VarChar(36)
  reviewId String @map("review_id") @db.VarChar(36)
  url      String @db.VarChar(255)
  type     String @default("IMAGE") // image hoac video

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("review_assets")
}

model ActivityLog {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String?  @map("user_id") @db.VarChar(36)
  action    String   @db.VarChar(255)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@map("activity_logs")
}

// ====================== ENUMS ======================
enum Role {
  ADMIN
  STAFF
  USER
}

enum OrderStatus {
  PENDING // Chờ xác nhận
  CONFIRMED // Đã xác nhận đơn hàng
  PROCESSING // Đang đóng gói
  SHIPPING // Đang giao hàng
  DELIVERED // Giao hàng thành công
  CANCELLED // Đơn hàng bị hủy
  RETURNED // Khách trả hàng
  FAILED // Giao hàng thất bại
}

enum PaymentMethod {
  COD // thanh toán khi nhận hàng
  E_WALLET // thanh toán qua ví điện tử
  PAYMENT_GATEWAY // thanh toán qua cổng thanh toán
  BANK_TRANSFER // thanh toán qua ngân hàng
}

enum PaymentStatus {
  PENDING // Chưa thanh toán
  PROCESSING // Đang xử lý
  PAID // Đã thanh toán thành công
  FAILED // Thanh toán lỗi
  REFUNDED // Đã hoàn tiền cho khách
}

enum TransactionStatus {
  SUCCESS
  FAILED
  PENDING
}

enum RoomStatus {
  OPEN
  CLOSED
}

enum AssetType {
  IMAGE
  GLB
  USDZ
}

enum UserStatus {
  ACTIVE
  BANNED
  INACTIVE
}
